# Edge/Dockerfile.light
FROM python:3.9-slim
WORKDIR /app

# Copy light requirements first for layer caching
COPY requirements.light.txt .

# Install only lightweight dependencies
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.light.txt

# Copy application code (.dockerignore keeps it lean)
COPY . .

ENV PYTHONUNBUFFERED=1
CMD ["python", "-u", "app.py"]
